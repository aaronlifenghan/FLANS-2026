    "#track1_output#\n",
    "\n",
    "import pandas as pd\n",
    "\n",
    "INPUT_TSV  = \"track_1_saq_input_eval.tsv\"   \n",
    "OUTPUT_TSV = \"track_1_saq_prediction_eval.tsv\"\n",
    "\n",
    "# 1) input tsv file\n",
    "df = pd.read_csv(INPUT_TSV, sep=\"\\t\", dtype=str)\n",
    "df = df.fillna(\"\")\n",
    "assert \"id\" in df.columns and \"text\" in df.columns, df.columns\n",
    "df[\"question\"] = df[\"text\"]\n",
    "\n",
    "# 2) filtering languages:filter id like zh-SG_015 / es-EC_022 / en-GB_030\n",
    "df[\"lang\"] = df[\"id\"].str.split(\"-\").str[0]\n",
    "df_run = df[df[\"lang\"].isin([\"zh\", \"es\", \"en\"])].copy()\n",
    "\n",
    "print(\"Total rows:\", len(df))\n",
    "print(\"Run rows (zh/es/en):\", len(df_run))\n",
    "print(df_run.head(3))\n",
    "\n",
    "# 3) Retrieve + Threshold Filtering\n",
    "def retrieve_context(question: str, k: int = 4):\n",
    "    # distance score\n",
    "    docs_scores = vectordb.similarity_search_with_score(question, k=k)\n",
    "    threshold = 0.70  \n",
    "    kept = [(d, s) for d, s in docs_scores if s <= threshold]\n",
    "    docs = [d for d, _ in kept]\n",
    "    return docs\n",
    "\n",
    "\n",
    "def postprocess(ans: str) -> str:\n",
    "    # Generate short answers: take the first line + remove blankspace.\n",
    "    ans = (ans or \"\").strip()\n",
    "    ans = ans.splitlines()[0].strip()\n",
    "    return ans\n",
    "\n",
    "# 4) Generate one by one\n",
    "preds = []\n",
    "for idx, row in enumerate(df_run.itertuples(index=False), start=1):\n",
    "    qid = row.id\n",
    "    question = row.question\n",
    "\n",
    "    docs = retrieve_context(question, k=4)\n",
    "    context = \"\\n\\n\".join(d.page_content for d in docs) if docs else \"\"\n",
    "\n",
    "    answer = chain.run({\"context\": context, \"question\": question})\n",
    "    answer = postprocess(answer)\n",
    "\n",
    "    preds.append({\"id\": qid, \"prediction\": answer})\n",
    "\n",
    "    # Printing progress\n",
    "    if idx % 100 == 0:\n",
    "        print(f\"[{idx}/{len(df_run)}] {qid} -> {answer}\")\n",
    "\n",
    "# 5) Out TSV\n",
    "out_df = pd.DataFrame(preds)[[\"id\", \"prediction\"]]\n",
    "out_df.to_csv(OUTPUT_TSV, sep=\"\\t\", index=False)\n",
    "\n",
    "print(\"Saved:\", OUTPUT_TSV)"
   ]
