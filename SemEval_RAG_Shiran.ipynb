    "\n",
    "#test code for single queston#\n",
    "def format_context(docs, max_chars=1500):\n",
    "    \"\"\"\n",
    "    Join retrieved docs into a single context string.\n",
    "    Also collect source info for debugging.\n",
    "    Returns:\n",
    "      - context_str\n",
    "      - sources: list of dicts (file / lang / source / preview)\n",
    "    \"\"\"\n",
    "    parts = []\n",
    "    sources = []\n",
    "    total = 0\n",
    "\n",
    "    for i, d in enumerate(docs, start=1):\n",
    "        text = (d.page_content or \"\").strip()\n",
    "        if not text:\n",
    "            continue\n",
    "\n",
    "        meta = getattr(d, \"metadata\", {}) or {}\n",
    "        file_name = meta.get(\"file\", \"UNKNOWN_FILE\")\n",
    "        lang = meta.get(\"lang\", \"unknown\")\n",
    "        source = meta.get(\"source\", \"unknown\")\n",
    "\n",
    "        chunk = f\"{i}. {text}\"\n",
    "        if total + len(chunk) > max_chars:\n",
    "            break\n",
    "\n",
    "        parts.append(chunk)\n",
    "        total += len(chunk)\n",
    "\n",
    "        preview = text if len(text) <= 120 else text[:120] + \"...\"\n",
    "        sources.append({\n",
    "            \"rank\": i,\n",
    "            \"file\": file_name,\n",
    "            \"lang\": lang,\n",
    "            \"source\": source,\n",
    "            \"preview\": preview\n",
    "        })\n",
    "\n",
    "    return \"\\n\".join(parts), sources\n",
    "\n",
    "\n",
    "def answer_question(question, retriever, chain, k=6, show_context=False, show_sources=True):\n",
    "    \"\"\"\n",
    "    Retrieve top-k docs, build context, run the LLM chain,\n",
    "    and show which files the answer came from.\n",
    "    \"\"\"\n",
    "    docs = retriever.get_relevant_documents(question)\n",
    "\n",
    "    context, sources = format_context(docs, max_chars=1500)\n",
    "    result = chain.invoke({\"question\": question, \"context\": context})\n",
    "    answer = (result.get(\"text\") or \"\").strip()\n",
    "\n",
    "    # shared-task style: only first line\n",
    "    answer = answer.splitlines()[0].strip()\n",
    "\n",
    "    if show_sources:\n",
    "        print(\"\\n--- Retrieved Sources ---\")\n",
    "        if not sources:\n",
    "            print(\"(No documents retrieved)\")\n",
    "        else:\n",
    "            for s in sources:\n",
    "                print(\n",
    "                    f\"- #{s['rank']} | file={s['file']} | \"\n",
    "                    f\"lang={s['lang']} | source={s['source']} | \"\n",
    "                    f\"preview={s['preview']}\"\n",
    "                )\n",
    "        print(\"--- End Sources ---\\n\")\n",
    "\n",
    "    if show_context:\n",
    "        print(\"\\n--- Retrieved Context ---\")\n",
    "        print(context)\n",
    "        print(\"--- End Context ---\\n\")\n",
    "\n",
    "    return answer\n",
    "\n",
    "\n",
    "# ---- Interactive single-question mode ----\n",
    "question = \"中国的最高峰是？\"\n",
    "\n",
    "answer = answer_question(\n",
    "    question,\n",
    "    retriever=retriever,\n",
    "    chain=chain,\n",
    "    k=6,\n",
    "    show_context=False,\n",
    "    show_sources=True\n",
    ")\n",
    "\n",
    "print(\"Q:\", question)\n",
    "print(\"Answer:\", answer)\n",
    "\n"
   ]
  },
