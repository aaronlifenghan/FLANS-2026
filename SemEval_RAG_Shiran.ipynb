    "import pandas as pd\n",
    "import re\n",
    "\n",
    "INPUT_TSV  = \"track_2_mcq_input_eval.tsv\"        \n",
    "OUTPUT_TSV = \"track_2_mcq_prediction_eval.tsv\"\n",
    "\n",
    "# 1) Input TSV\n",
    "df = pd.read_csv(INPUT_TSV, sep=\"\\t\", dtype=str).fillna(\"\")\n",
    "need_cols = {\"option A\", \"option B\", \"option C\", \"option D\"}\n",
    "assert need_cols.issubset(df.columns), f\"Missing columns: {need_cols - set(df.columns)}\"\n",
    "\n",
    "# 2) Choose languages (id like zh-SG_015 / es-EC_022 / en-GB_030)\n",
    "df[\"lang\"] = df[\"id\"].str.split(\"-\").str[0].str.lower()\n",
    "df_run = df[df[\"lang\"].isin([\"zh\", \"es\", \"en\"])].copy()\n",
    "\n",
    "print(\"Total rows:\", len(df))\n",
    "print(\"Run rows (zh/es/en):\", len(df_run))\n",
    "print(df_run.head(3)[[\"id\",\"lang\",\"question\"]])\n",
    "\n",
    "# 3) Retrieve context\n",
    "def retrieve_context(question: str, k: int = 4):\n",
    "    # distance score\n",
    "    docs_scores = vectordb.similarity_search_with_score(question, k=k)\n",
    "    threshold = 0.70  \n",
    "    kept = [(d, s) for d, s in docs_scores if s <= threshold]\n",
    "    docs = [d for d, _ in kept]\n",
    "    return docs\n",
    "def build_mcq_question(question: str, a: str, b: str, c: str, d: str) -> str:\n",
    "    return (\n",
    "        f\"{question}\\n\\n\"\n",
    "        f\"Options:\\n\"\n",
    "        f\"A) {a}\\n\"\n",
    "        f\"B) {b}\\n\"\n",
    "        f\"C) {c}\\n\"\n",
    "        f\"D) {d}\\n\\n\"\n",
    "        f\"Respond with ONLY ONE LETTER: A, B, C, or D.\"\n",
    "    )\n",
    "\n",
    "def parse_choice(text: str):\n",
    "    if text is None:\n",
    "        return None\n",
    "    t = str(text).strip()\n",
    "    t = t.splitlines()[0].strip().upper() \n",
    "    m = re.search(r\"\\b([ABCD])\\b\", t)\n",
    "    return m.group(1) if m else None\n",
    "\n",
    "\n",
    "def onehot(choice: str):\n",
    "    if choice not in {\"A\",\"B\",\"C\",\"D\"}:\n",
    "        choice = \"A\"  \n",
    "    return {\n",
    "        \"A\": 1 if choice==\"A\" else 0,\n",
    "        \"B\": 1 if choice==\"B\" else 0,\n",
    "        \"C\": 1 if choice==\"C\" else 0,\n",
    "        \"D\": 1 if choice==\"D\" else 0,\n",
    "    }\n",
    "# 4) Generate one by one\n",
    "preds = []\n",
    "for idx, row in enumerate(df_run.itertuples(index=False), start=1):\n",
    "    qid = row.id\n",
    "\n",
    "    docs = retrieve_context(row.question, k=4)\n",
    "    context = \"\\n\\n\".join(d.page_content for d in docs) if docs else \"\"\n",
    "\n",
    "    mcq_q = build_mcq_question(\n",
    "        row.question, row.option_A, row.option_B, row.option_C, row.option_D\n",
    "    )\n",
    "\n",
    "    raw = chain.run({\"context\": context, \"question\": mcq_q})\n",
    "    choice = parse_choice(raw)\n",
    "    oh = onehot(choice)\n",
    "\n",
    "    preds.append({\"id\": qid, **oh})\n",
    "\n",
    "    if idx % 5 == 0 or idx == len(df_run):\n",
    "        print(f\"[{idx}/{len(df_run)}] {qid} | docs={len(docs)} | raw='{str(raw).strip()[:25]}' | parsed={choice}\")\n",
    "\n",
    "# 5) Output TSV\n",
    "out_df = pd.DataFrame(preds)[[\"id\",\"A\",\"B\",\"C\",\"D\"]]\n",
    "out_df.to_csv(OUTPUT_TSV, sep=\"\\t\", index=False, encoding=\"utf-8\")  \n",
    "print(\"Saved:\", OUTPUT_TSV)\n",
    "out_df.head(10)\n",
    "\n"
   ]
